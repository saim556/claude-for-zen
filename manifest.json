{
  "manifest_version": 2,
  "name": "Claude for Zen",
  "version": "1.1.0",
  "description": "A helping hand across all your tabs. Claude can navigate, click, and fill forms in your browser.",
  "author": "Claude for Zen",

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "cookies",
    "notifications",
    "<all_urls>"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "claude-for-zen@anthropic.com",
      "strict_min_version": "115.0"
    }
  },

  "sidebar_action": {
    "default_title": "Claude",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },

  "page_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Toggle Claude sidebar",
    "show_matches": ["<all_urls>"]
  },

  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Toggle Claude sidebar"
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [
    "icons/*.png"
  ]
}
